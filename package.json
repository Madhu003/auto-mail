{
  "name": "auto-mail",
  "version": "1.0.0",
  "description": "Automated cold email sender for job hunting",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"npx dotenv-cli -e .env -- node --loader ts-node/esm src/index.ts\"",
    "agent": "npx dotenv-cli -e .env -- node --loader ts-node/esm src/agent.ts",
    "agent:md": "npx dotenv-cli -e .env -- node --loader ts-node/esm src/agentFromMarkdown.ts"
  },
  "keywords": [
    "email",
    "automation",
    "job-hunting"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/mcp-adapters": "^1.1.3",
    "dotenv": "^16.3.1",
    "langchain": "^1.5.2",
    "mongodb": "^7.4.0",
    "nodemailer": "^6.9.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
