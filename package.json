{
  "name": "auto-mail",
  "version": "1.0.0",
  "description": "Automated cold email sender for job hunting",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"npx dotenv-cli -e .env -- node --loader ts-node/esm src/index.ts\""
  },
  "keywords": [
    "email",
    "automation",
    "job-hunting"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
